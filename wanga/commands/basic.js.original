// Helper to send interactive buttons (simple reply/url/copy)
async function sendInteractive(sock, from, options, quotedMsg) {
    const { sendInteractiveMessage } = require('gifted-btns');
    try {
        return await sendInteractiveMessage(sock, from, {
            text: options.text,
            footer: options.footer || '> created by wanga',
            interactiveButtons: options.buttons || []
        }, { quoted: quotedMsg });
    } catch (error) {
        console.error('Interactive error:', error);
        await sock.sendMessage(from, { text: options.text }, { quoted: quotedMsg });
    }
}

// Helper to send dropdown menu (single_select)
async function sendDropdownMenu(sock, from, options, quotedMsg) {
    const { sendInteractiveMessage } = require('gifted-btns');
    try {
        return await sendInteractiveMessage(sock, from, {
            text: options.text,
            footer: options.footer || '> created by wanga',
            interactiveButtons: [{
                name: 'single_select',
                buttonParamsJson: JSON.stringify({
                    title: options.title || 'Select an option',
                    sections: options.sections
                })
            }]
        }, { quoted: quotedMsg });
    } catch (error) {
        console.error('Dropdown error:', error);
        await sock.sendMessage(from, { text: options.text }, { quoted: quotedMsg });
    }
}

// Helper to send buttons (simple reply buttons)
async function sendButtonMenu(sock, from, options, quotedMsg) {
    const { sendButtons } = require('gifted-btns');
    try {
        return await sendButtons(sock, from, {
            title: options.title || '𝐌𝐄𝐆𝐀𝐍-𝐌𝐃',
            text: options.text,
            footer: options.footer || '> created by wanga',
            image: options.image ? { url: options.image } : null,
            buttons: options.buttons || []
        }, { quoted: quotedMsg });
    } catch (error) {
        console.error('Button error:', error);
        await sock.sendMessage(from, { text: options.text }, { quoted: quotedMsg });
    }
}

