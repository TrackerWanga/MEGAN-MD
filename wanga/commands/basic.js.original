// ==================== BASIC COMMANDS ====================
commands.push({
    name: 'ping',
    description: 'Check bot response time',
    aliases: ['p'],
    async execute({ msg, from, sender, args, bot, sock, react, reply, buttons }) {
        const start = Date.now();
        await new Promise(resolve => setTimeout(resolve, 50));
        const ping = Date.now() - start;

        await sendButtonMenu(sock, from, {
            title: '⚡ Bot Speed',
            text: `*Pong!* 🏓\n\n📡 Response: ${ping}ms`,
            footer: '> created by wanga',
            buttons: [
                { id: 'uptime_cmd', text: '⏱️ Uptime' },
                { id: 'menu_cmd', text: '📋 Menu' },
                { name: 'cta_url', buttonParamsJson: JSON.stringify({ display_text: '📢 Channel', url: CHANNEL_LINK }) }
            ]
        }, msg);
        await react('✅');
    }
});

commands.push({
    name: 'uptime',
    description: 'Show bot uptime',
    aliases: ['runtime'],
    async execute({ msg, from, sender, bot, sock, react, reply, buttons }) {
        const uptime = process.uptime();
        const days = Math.floor(uptime / 86400);
        const hours = Math.floor((uptime % 86400) / 3600);
        const minutes = Math.floor((uptime % 3600) / 60);
        const seconds = Math.floor(uptime % 60);

        await sendButtonMenu(sock, from, {
            title: '⏱️ Bot Uptime',
            text: `📅 *Days:* ${days}\n⏰ *Hours:* ${hours}\n⏱️ *Minutes:* ${minutes}\n⏲️ *Seconds:* ${seconds}`,
            footer: '> created by wanga',
            buttons: [
                { id: 'ping_cmd', text: '⚡ Ping' },
                { id: 'menu_cmd', text: '📋 Menu' },
                { name: 'cta_url', buttonParamsJson: JSON.stringify({ display_text: '📢 Channel', url: CHANNEL_LINK }) }
            ]
        }, msg);
        await react('✅');
    }
});

commands.push({
    name: 'info',
    description: 'Show bot information',
    aliases: ['bot'],
    async execute({ msg, from, sender, bot, sock, react, reply, buttons }) {
        const now = moment().tz(config.TIMEZONE || 'Africa/Nairobi');
        const timeStr = now.format('h:mm A');
        const dateStr = now.format('DD/MM/YYYY');

        const uptime = process.uptime();
        const days = Math.floor(uptime / 86400);
        const hours = Math.floor((uptime % 86400) / 3600);

        const totalMem = os.totalmem() / (1024 * 1024 * 1024);
        const freeMem = os.freemem() / (1024 * 1024 * 1024);
        const usedMem = (totalMem - freeMem).toFixed(2);
        const totalMemFixed = totalMem.toFixed(2);

        const infoText = '📱 *BOT INFO*\n\n' +
            `👤 *Owner:* ${config.OWNER_NAME}\n` +
            `📞 *Phone:* ${config.OWNER_NUMBER}\n` +
            `🤖 *Bot:* ${config.BOT_NAME}\n` +
            `🔧 *Prefix:* ${config.PREFIX}\n` +
            `⚙️ *Mode:* ${config.MODE}\n` +
            `📚 *Commands:* ${bot.commands.size}\n` +
            `⏱️ *Uptime:* ${days}d ${hours}h\n` +
            `🕒 *Time:* ${timeStr}\n` +
            `📅 *Date:* ${dateStr}\n` +
            `💾 *RAM:* ${usedMem}GB/${totalMemFixed}GB`;

        await sendButtonMenu(sock, from, {
            title: '📱 Bot Information',
            text: infoText,
            footer: '> created by wanga',
            image: BOT_LOGO,
            buttons: [
                { id: 'status_cmd', text: '📊 Status' },
                { id: 'menu_cmd', text: '📋 Menu' },
                { name: 'cta_url', buttonParamsJson: JSON.stringify({ display_text: '📢 Channel', url: CHANNEL_LINK }) }
            ]
        }, msg);
        await react('✅');
    }
});

commands.push({
    name: 'status',
    description: 'Show bot status',
    aliases: ['stats'],
    async execute({ msg, from, sender, bot, sock, react, reply, buttons }) {
        const uptime = process.uptime();
        const days = Math.floor(uptime / 86400);
        const hours = Math.floor((uptime % 86400) / 3600);
        const minutes = Math.floor((uptime % 3600) / 60);
        const seconds = Math.floor(uptime % 60);

        const memory = process.memoryUsage();
        const usedMB = Math.round(memory.heapUsed / 1024 / 1024);
        const totalMB = Math.round(os.totalmem() / 1024 / 1024);

        const statusText = '📊 *BOT STATUS*\n\n' +
            `⏱️ *Uptime:* ${days}d ${hours}h ${minutes}m ${seconds}s\n` +
            `💾 *Memory:* ${usedMB}MB / ${totalMB}MB\n` +
            `📚 *Commands:* ${bot.commands.size}\n` +
            `⚡ *Node:* ${process.version}\n` +
            `💻 *Platform:* ${process.platform}`;

        await sendButtonMenu(sock, from, {
            title: '📊 Bot Status',
            text: statusText,
            footer: '> created by wanga',
            buttons: [
                { id: 'info_cmd', text: 'ℹ️ Info' },
                { id: 'menu_cmd', text: '📋 Menu' },
                { name: 'cta_url', buttonParamsJson: JSON.stringify({ display_text: '📢 Channel', url: CHANNEL_LINK }) }
            ]
        }, msg);
        await react('✅');
    }
});

