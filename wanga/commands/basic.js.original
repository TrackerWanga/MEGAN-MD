// ==================== MAIN MENU COMMAND ====================
commands.push({
    name: 'menu',
    description: 'Show bot menu with dropdown buttons',
    aliases: ['help', 'cmds', 'allmenu', '📋 Menu'],
    async execute({ msg, from, sender, bot, sock, react, reply, buttons }) {
        const now = moment().tz(config.TIMEZONE || 'Africa/Nairobi');
        const timeStr = now.format('h:mm A');
        const dateStr = now.format('DD/MM/YYYY');

        const uptime = process.uptime();
        const days = Math.floor(uptime / 86400);
        const hours = Math.floor((uptime % 86400) / 3600);
        const minutes = Math.floor((uptime % 3600) / 60);

        const totalMem = os.totalmem() / (1024 * 1024 * 1024);
        const freeMem = os.freemem() / (1024 * 1024 * 1024);
        const usedMem = (totalMem - freeMem).toFixed(2);
        const totalMemFixed = totalMem.toFixed(2);

        const menuText = '*𝐌𝐄𝐆𝐀𝐍 𝐌𝐃*\n\n' +
            '✧･ﾟ: ✧･ﾟ:  𝐒𝐘𝐒𝐓𝐄𝐌  :･ﾟ✧:･ﾟ✧\n' +
            `➤ Version  : 3.0.0\n` +
            `➤ Owner    : ${config.OWNER_NAME}\n` +
            `➤ Prefix   : ${config.PREFIX}\n` +
            `➤ Commands : ${bot.commands.size}\n` +
            `➤ Uptime   : ${days}d ${hours}h ${minutes}m\n` +
            `➤ Time     : ${timeStr}\n` +
            `➤ Date     : ${dateStr}\n` +
            `➤ RAM      : ${usedMem}GB/${totalMemFixed}GB\n\n` +
            '📌 *Click a category button below to see available commands with examples*';

        await sendButtonMenu(sock, from, {
            title: '🎯 MEGAN-MD MAIN MENU',
            text: menuText,
            footer: '> created by wanga',
            image: BOT_LOGO,
            buttons: [
                { id: 'show_ai_dropdown', text: '🤖 AI' },
                { id: 'show_ai_image_dropdown', text: '🎨 AI Image' },
                { id: 'show_downloader_dropdown', text: '⬇️ Downloader' },
                { id: 'show_group_dropdown', text: '👥 Group' },
                { id: 'show_media_dropdown', text: '🎵 Media' },
                { id: 'show_search_dropdown', text: '🔍 Search' },
                { id: 'show_tools_dropdown', text: '🛠️ Tools' },
                { id: 'show_features_dropdown', text: '⚙️ Features' },
                { name: 'cta_url', buttonParamsJson: JSON.stringify({ display_text: '📢 Channel', url: CHANNEL_LINK }) }
            ]
        }, msg);
        await react('✅');
    }
});

