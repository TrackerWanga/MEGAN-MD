        }
        
        const target = args[0].toLowerCase();
        const value = args[1]?.toLowerCase();
        
        if (target === 'dm') {
            if (!value || !['on', 'off'].includes(value)) return reply('Use: .autorecording dm on/off');
            await bot.db.setSetting('autorecording_dm', value);
            await react('✅');
            return reply(`✅ Auto-recording in DMs set to: ${value.toUpperCase()}`);
        }
        
        if (target === 'group') {
            if (!value || !['on', 'off'].includes(value)) return reply('Use: .autorecording group on/off');
            await bot.db.setSetting('autorecording_group', value);
            await react('✅');
            return reply(`✅ Auto-recording in groups set to: ${value.toUpperCase()}`);
        }
        
        if (target === 'both') {
            if (!value || !['on', 'off'].includes(value)) return reply('Use: .autorecording both on/off');
