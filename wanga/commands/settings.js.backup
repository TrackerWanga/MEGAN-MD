// MEGAN-MD Settings Commands

const config = require('../../megan/config');
const timeUtils = require('../../megan/lib/timeUtils');

const commands = [];

// ============================================
// AUTO-TYPING COMMAND
// ============================================
commands.push({
    name: 'autotyping',
    description: 'Toggle auto-typing (dm/group/both/off)',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        if (args.length === 0) {
            const dm = await bot.db.getSetting('autotyping_dm', 'off');
            const group = await bot.db.getSetting('autotyping_group', 'off');
            return reply(`📝 *AUTO-TYPING*\n\nDM: ${dm === 'on' ? '✅ ON' : '❌ OFF'}\nGroup: ${group === 'on' ? '✅ ON' : '❌ OFF'}\n\n*Usage:*\n.autotyping dm on/off\n.autotyping group on/off\n.autotyping both on/off`);
        }
        
        const target = args[0].toLowerCase();
        const value = args[1]?.toLowerCase();
        
        if (target === 'dm') {
            if (!value || !['on', 'off'].includes(value)) return reply('Use: .autotyping dm on/off');
            await bot.db.setSetting('autotyping_dm', value);
            await react('✅');
            return reply(`✅ Auto-typing in DMs set to: ${value.toUpperCase()}`);
        }
        
        if (target === 'group') {
            if (!value || !['on', 'off'].includes(value)) return reply('Use: .autotyping group on/off');
            await bot.db.setSetting('autotyping_group', value);
            await react('✅');
            return reply(`✅ Auto-typing in groups set to: ${value.toUpperCase()}`);
        }
        
        if (target === 'both') {
            if (!value || !['on', 'off'].includes(value)) return reply('Use: .autotyping both on/off');
            await bot.db.setSetting('autotyping_dm', value);
            await bot.db.setSetting('autotyping_group', value);
            await react('✅');
            return reply(`✅ Auto-typing in both DMs and groups set to: ${value.toUpperCase()}`);
        }
        
        return reply(`❌ Unknown option. Use: dm, group, or both`);
    }
});

// ============================================
// AUTO-RECORDING COMMAND
// ============================================
