// ============================================
// ANTI-LINK WARN COUNT
// ============================================
commands.push({
    name: 'antilinkwarncount',
    description: 'Set number of warnings before kicking',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isGroup, isAdmin, isOwner }) {
        if (!isGroup) return reply('❌ This command only works in groups!');
        if (!isAdmin && !isOwner) return reply('❌ You must be an admin to use this command!');
        
        if (args.length === 0) {
            const count = await bot.db.getGroupSetting(from, 'ANTILINK_WARN_COUNT', '3');
            return reply(`⚠️ *ANTI-LINK WARN COUNT*\n\nCurrent: ${count} warnings before kick\n\n*Usage:* .antilinkwarncount <number>\n*Example:* .antilinkwarncount 5`);
        }
        
        const count = parseInt(args[0]);
        if (isNaN(count) || count < 1 || count > 10) {
            return reply(`❌ Please provide a number between 1 and 10`);
        }
        
        await bot.db.setGroupSetting(from, 'ANTILINK_WARN_COUNT', String(count));
        await react('✅');
        return reply(`✅ Users will be kicked after ${count} warnings.`);
    }
});

// ============================================
// SHOW ALL SETTINGS
// ============================================
commands.push({
    name: 'allsettings',
    description: 'Show all bot settings',
    aliases: ['config'],
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        const settings = {
            // Presence
            autotyping_dm: await bot.db.getSetting('autotyping_dm', 'off'),
            autotyping_group: await bot.db.getSetting('autotyping_group', 'off'),
            autorecording_dm: await bot.db.getSetting('autorecording_dm', 'off'),
            autorecording_group: await bot.db.getSetting('autorecording_group', 'off'),
            presence_dm: await bot.db.getSetting('presence_dm', 'typing'),
            presence_group: await bot.db.getSetting('presence_group', 'typing'),
            
            // Chat
            chatbot: await bot.db.getSetting('chatbot', 'off'),
            autoread: await bot.db.getSetting('autoread', 'off'),
            autoreact: await bot.db.getSetting('autoreact', 'off'),
            antidelete: await bot.db.getSetting('antidelete', 'on'),
            antiedit: await bot.db.getSetting('antiedit', 'on'),
            anticall: await bot.db.getSetting('anticall', 'off'),
            autoviewonce: await bot.db.getSetting('autoviewonce', 'on'),
            
            // Status
            status_auto_view: await bot.db.getSetting('status_auto_view', 'on'),
            status_auto_react: await bot.db.getSetting('status_auto_react', 'off'),
            status_auto_download: await bot.db.getSetting('status_auto_download', 'off'),
            status_react_emojis: await bot.db.getSetting('status_react_emojis', '💛,❤️,💜,🤍,💙,👍,🔥'),
            
            // Group
            welcome: await bot.db.getSetting('welcome', 'off'),
            goodbye: await bot.db.getSetting('goodbye', 'off'),
            welcomemessage: await bot.db.getSetting('welcomemessage', 'Hey @user welcome!'),
            goodbyemessage: await bot.db.getSetting('goodbyemessage', 'Goodbye @user! 👋'),
            
            // Bot
            mode: await bot.db.getSetting('mode', 'public'),
            prefix: await bot.db.getSetting('prefix', '.'),
            timezone: await bot.db.getSetting('timezone', 'Africa/Nairobi'),
            bot_name: await bot.db.getSetting('bot_name', config.BOT_NAME),
            owner_name: await bot.db.getSetting('owner_name', config.OWNER_NAME),
            footer: await bot.db.getSetting('footer', config.FOOTER)
        };
        
        const currentTime = await timeUtils.getCurrentTimeString(bot.db);
        
        let message = `⚙️ *ALL SETTINGS*\n\n`;
        message += `🕐 *Time:* ${currentTime}\n`;
        message += `🌍 *Timezone:* ${settings.timezone}\n\n`;
        
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `📱 *PRESENCE*\n`;
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `• Auto-Typing DM: ${settings.autotyping_dm === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-Typing Group: ${settings.autotyping_group === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-Recording DM: ${settings.autorecording_dm === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-Recording Group: ${settings.autorecording_group === 'on' ? '✅' : '❌'}\n`;
        message += `• Presence DM: ${settings.presence_dm}\n`;
        message += `• Presence Group: ${settings.presence_group}\n\n`;
        
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `💬 *MESSAGES*\n`;
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `• Chatbot: ${settings.chatbot === 'off' ? '❌ OFF' : `✅ ${settings.chatbot.toUpperCase()}`}\n`;
        message += `• Auto-Read: ${settings.autoread === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-React: ${settings.autoreact === 'on' ? '✅' : '❌'}\n`;
        message += `• Anti-Delete: ${settings.antidelete === 'on' ? '✅' : '❌'}\n`;
        message += `• Anti-Edit: ${settings.antiedit === 'on' ? '✅' : '❌'}\n`;
        message += `• Anti-Call: ${settings.anticall === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-View-Once: ${settings.autoviewonce === 'on' ? '✅' : '❌'}\n\n`;
        
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `📱 *STATUS*\n`;
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `• Auto-View: ${settings.status_auto_view === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-React: ${settings.status_auto_react === 'on' ? '✅' : '❌'}\n`;
        message += `• Auto-Download: ${settings.status_auto_download === 'on' ? '✅' : '❌'}\n`;
        message += `• React Emojis: ${settings.status_react_emojis}\n\n`;
        
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `👥 *GROUP*\n`;
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `• Welcome: ${settings.welcome === 'on' ? '✅' : '❌'}\n`;
        message += `• Goodbye: ${settings.goodbye === 'on' ? '✅' : '❌'}\n\n`;
        
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `🤖 *BOT*\n`;
        message += `━━━━━━━━━━━━━━━━━━━\n`;
        message += `• Mode: ${settings.mode === 'public' ? '🌍 PUBLIC' : '🔒 PRIVATE'}\n`;
        message += `• Prefix: ${settings.prefix}\n`;
        message += `• Bot Name: ${settings.bot_name}\n`;
        message += `• Owner: ${settings.owner_name}\n`;
        message += `• Footer: ${settings.footer}\n\n`;
        
        message += `> created by wanga`;
        
        await sock.sendMessage(from, { text: message }, { quoted: msg });
        await react('✅');
    }
});

module.exports = { commands };
