// ============================================
// PRESENCE COMMAND
// ============================================
commands.push({
    name: 'presence',
    description: 'Set presence mode (online/typing/recording/offline)',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        if (args.length === 0) {
            const dm = await bot.db.getSetting('presence_dm', 'typing');
            const group = await bot.db.getSetting('presence_group', 'typing');
            return reply(`🟢 *PRESENCE*\n\nDM: ${dm}\nGroup: ${group}\n\n*Usage:*\n.presence dm typing/online/recording/offline\n.presence group typing/online/recording/offline`);
        }
        
        const target = args[0].toLowerCase();
        const value = args[1]?.toLowerCase();
        
        if (!value || !['typing', 'online', 'recording', 'offline'].includes(value)) {
            return reply(`❌ Invalid presence. Use: typing, online, recording, or offline`);
        }
        
        if (target === 'dm') {
            await bot.db.setSetting('presence_dm', value);
            await react('✅');
            return reply(`✅ DM presence set to: ${value}`);
        }
        
        if (target === 'group') {
            await bot.db.setSetting('presence_group', value);
            await react('✅');
            return reply(`✅ Group presence set to: ${value}`);
        }
        
        return reply(`❌ Unknown option. Use: dm or group`);
    }
});

// ============================================
// CHATBOT COMMAND
// ============================================
commands.push({
    name: 'chatbot',
    description: 'Toggle chatbot (dm/group/both/off)',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        if (args.length === 0) {
            const current = await bot.db.getSetting('chatbot', 'off');
            return reply(`🤖 *CHATBOT*\n\nCurrent: ${current === 'on' ? '✅ ON' : '❌ OFF'}\n\n*Options:*\n.chatbot on - Enable in DMs only\n.chatbot group on - Enable in groups only\n.chatbot both on - Enable everywhere\n.chatbot off - Disable\n\n*Examples:*\n.chatbot on\n.chatbot group on\n.chatbot both on\n.chatbot off`);
        }
        
        const option = args[0].toLowerCase();
        
        if (option === 'on') {
            await bot.db.setSetting('chatbot', 'dm');
            await react('✅');
            return reply(`✅ Chatbot enabled for DMs only`);
        }
        
        if (option === 'group') {
            if (args[1]?.toLowerCase() === 'on') {
                await bot.db.setSetting('chatbot', 'group');
                await react('✅');
                return reply(`✅ Chatbot enabled for groups only`);
            }
            return reply(`Use: .chatbot group on`);
        }
        
        if (option === 'both' && args[1]?.toLowerCase() === 'on') {
            await bot.db.setSetting('chatbot', 'both');
            await react('✅');
            return reply(`✅ Chatbot enabled for DMs and groups`);
        }
        
        if (option === 'off') {
            await bot.db.setSetting('chatbot', 'off');
            await react('✅');
            return reply(`❌ Chatbot disabled`);
        }
        
        return reply(`❌ Invalid option. Use: on, group on, both on, or off`);
    }
});

// ============================================
// WELCOME COMMAND
// ============================================
commands.push({
    name: 'welcome',
    description: 'Toggle welcome messages in group',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isGroup, isAdmin, isOwner }) {
        if (!isGroup) return reply('❌ This command only works in groups!');
        if (!isAdmin && !isOwner) return reply('❌ You must be an admin to use this command!');
        
        if (args.length === 0) {
            const enabled = await bot.db.getSetting('welcome', 'off');
            const msgText = await bot.db.getSetting('welcomemessage', 'Hey @user welcome to our group! Hope you enjoy and connect with everyone.');
            return reply(`👋 *WELCOME*\n\nStatus: ${enabled === 'on' ? '✅ ON' : '❌ OFF'}\nMessage: ${msgText}\n\n*Commands:*\n.welcome on/off\n.setwelcomemsg <message>`);
        }
        
        const option = args[0].toLowerCase();
        
        if (option === 'on') {
            await bot.db.setSetting('welcome', 'on');
            await react('✅');
            return reply(`✅ Welcome messages enabled for this group!`);
        }
        
        if (option === 'off') {
            await bot.db.setSetting('welcome', 'off');
            await react('✅');
            return reply(`❌ Welcome messages disabled for this group!`);
        }
        
        return reply(`❌ Use: .welcome on or .welcome off`);
    }
});

// ============================================
// SET WELCOME MESSAGE
// ============================================
commands.push({
    name: 'setwelcomemsg',
    description: 'Set custom welcome message',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isGroup, isAdmin, isOwner }) {
        if (!isGroup) return reply('❌ This command only works in groups!');
        if (!isAdmin && !isOwner) return reply('❌ You must be an admin to use this command!');
        
        if (args.length === 0) {
            const current = await bot.db.getSetting('welcomemessage', 'Hey @user welcome to our group!');
            return reply(`📝 *WELCOME MESSAGE*\n\nCurrent: "${current}"\n\n*Usage:* .setwelcomemsg Your message here\n\n*Note:* Use @user to mention the new member`);
        }
        
        const message = args.join(' ');
        await bot.db.setSetting('welcomemessage', message);
        await react('✅');
        return reply(`✅ Welcome message updated!\n\nNew message: "${message}"`);
    }
});

// ============================================
// MODE COMMAND
// ============================================
commands.push({
    name: 'mode',
    description: 'Set bot mode (public/private)',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        if (args.length === 0) {
            const mode = await bot.db.getSetting('mode', 'public');
            return reply(`⚙️ *BOT MODE*\n\nCurrent: ${mode === 'public' ? '🌍 PUBLIC' : '🔒 PRIVATE'}\n\n*Public:* Anyone can use commands\n*Private:* Only owner can use commands\n\n*Usage:* .mode public or .mode private`);
        }
        
        const mode = args[0].toLowerCase();
        
        if (mode === 'public') {
            await bot.db.setSetting('mode', 'public');
            await react('✅');
            return reply(`🌍 Bot mode set to: PUBLIC\n\nAnyone can now use commands.`);
        }
        
        if (mode === 'private') {
            await bot.db.setSetting('mode', 'private');
            await react('✅');
            return reply(`🔒 Bot mode set to: PRIVATE\n\nOnly owner can now use commands.`);
        }
        
        return reply(`❌ Invalid mode. Use: public or private`);
    }
});

// ============================================
// PREFIX COMMAND
// ============================================
commands.push({
    name: 'prefix',
    description: 'Change command prefix',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        if (args.length === 0) {
            const prefix = await bot.db.getSetting('prefix', config.PREFIX);
            return reply(`🔧 *COMMAND PREFIX*\n\nCurrent: ${prefix}\n\n*Usage:* .prefix <new_prefix>\n*Example:* .prefix !`);
        }
        
        const newPrefix = args[0];
        if (newPrefix.length !== 1) {
            return reply(`❌ Prefix must be a single character!`);
        }
        
        await bot.db.setSetting('prefix', newPrefix);
        await react('✅');
        return reply(`✅ Command prefix changed to: ${newPrefix}\n\nAll commands now start with ${newPrefix}`);
    }
});

// ============================================
// TIMEZONE COMMAND
// ============================================
commands.push({
    name: 'timezone',
    description: 'Set bot timezone',
    async execute({ msg, from, sender, args, bot, sock, react, reply, isOwner }) {
        if (!isOwner) return reply('❌ Owner only command!');
        
        if (args.length === 0) {
            const current = await bot.db.getSetting('timezone', 'Africa/Nairobi');
            return reply(`🌍 *TIMEZONE*\n\nCurrent: ${current}\n\n*Usage:* .timezone Africa/Nairobi\n\n*Common timezones:*\n• Africa/Nairobi\n• Africa/Lagos\n• America/New_York\n• Europe/London\n• Asia/Dubai\n• Asia/Tokyo`);
        }
        
        const tz = args[0];
        
        // Check if timezone exists
        const moment = require('moment-timezone');
        if (!moment.tz.zone(tz)) {
            return reply(`❌ Invalid timezone. Use: .timezone Africa/Nairobi\n\nSee all timezones: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones`);
        }
        
        await bot.db.setSetting('timezone', tz);
        await react('✅');
        
        const currentTime = await timeUtils.getCurrentTimeString(bot.db);
        return reply(`✅ Timezone set to: ${tz}\n\nCurrent time: ${currentTime}`);
    }
});

