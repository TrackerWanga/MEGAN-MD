# ============================================
# MEGAN-MD BOT CONFIGURATION
# ============================================
# Copy this file as .env and fill in your details
# ============================================

# ===== SESSION (REQUIRED - PASTE YOUR SESSION HERE) =====
# This is the MOST IMPORTANT setting!
# Get this from pairing code or QR code
# It should be a long JSON string starting with {"noiseKey":{...
SESSION={"noiseKey":{"private":{"type":"Buffer","data":"..."}}}

# ===== BOT IDENTITY =====
# Your bot's display name
BOT_NAME=𝐌𝐄𝐆𝐀𝐍-𝐌𝐃

# Your name as the bot owner
OWNER_NAME=Wanga

# Your phone number with country code (no spaces, no +)
# Example: 254712345678
OWNER_NUMBER=254758476795

# Command prefix (default: .)
PREFIX=.

# Bot mode (public/private)
# public - anyone can use commands
# private - only owner can use commands
MODE=public

# ===== FEATURE TOGGLES =====
# Master switches for main features (on/off)
AUTO_REACT=off
AUTO_READ=off
AUTO_BIO=off
ANTI_DELETE=on
ANTI_LINK=off
ANTI_CALL=off
CHATBOT=off

# Auto-react specific toggles (on/off)
AUTO_REACT_PM=off
AUTO_REACT_GROUP=off

# Auto-read specific toggles (on/off)
AUTO_READ_PM=off
AUTO_READ_GROUP=off

# Anti-link settings
ANTI_LINK_ACTION=delete     # delete/warn/kick
ANTI_LINK_WARNING=3         # warnings before kick (1-10)
ANTI_LINK_MESSAGE=⚠️ Links are not allowed in this group!

# Anti-call settings
ANTI_CALL_MESSAGE=📞 Calls are not allowed! I will reject your call.

# ===== PRESENCE SETTINGS =====
# Presence in private messages (online/typing/recording/offline)
PRESENCE_PM=typing

# Presence in groups (online/typing/recording/offline)
PRESENCE_GROUP=typing

# Auto typing indicator (dm/group/both/off)
AUTO_TYPING=off

# Auto recording indicator (dm/group/both/off)
AUTO_RECORDING=off

# ===== STATUS FEATURES =====
# Auto-view statuses (on/off)
AUTO_VIEW_STATUS=on

# Auto-download statuses (on/off)
AUTO_DOWNLOAD_STATUS=off

# Auto-react to statuses (on/off)
AUTO_REACT_STATUS=off

# Emojis for status reactions (comma separated)
STATUS_REACT_EMOJIS=💛,❤️,💜,🤍,💙,👍,🔥

# Auto-reply to statuses (on/off)
AUTO_REPLY_STATUS=off

# Text for auto-reply to statuses
STATUS_REPLY_TEXT=✅ Status viewed via Megan-MD

# Auto-save statuses to DM (on/off)
AUTO_SAVE_STATUS=off

# Auto-save view once media (on/off)
AUTO_VIEW_ONCE=off

# ===== WELCOME/GOODBYE SETTINGS =====
# Welcome messages (on/off)
WELCOME=off

# Welcome message text (use @user to mention)
WELCOME_MESSAGE=Hey @user welcome to our group! Hope you enjoy and connect with everyone.

# Welcome as audio (TTS) (on/off)
WELCOME_AUDIO=off

# Goodbye messages (on/off)
GOODBYE=off

# Goodbye message text (use @user to mention)
GOODBYE_MESSAGE=Goodbye @user! 👋

# Goodbye as audio (TTS) (on/off)
GOODBYE_AUDIO=off

# ===== PRIVACY SETTINGS =====
# Last seen privacy (all/contacts/none)
LAST_SEEN=all

# Profile picture privacy (all/contacts/none)
PROFILE_PIC=all

# Status privacy (all/contacts/none)
STATUS_PRIVACY=all

# Read receipts (all/none)
READ_RECEIPTS=all

# Online privacy (all/match_last_seen)
ONLINE_PRIVACY=all

# Auto-block unknown numbers (on/off)
BLOCK_UNKNOWN=off

# Auto-block private numbers (on/off)
BLOCK_PRIVATE=off

# ===== CHATBOT AI SETTINGS =====
# AI response mode (short/normal/detailed)
AI_MODE=normal

# AI model (keep as is)
AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Cloudflare worker URL (keep as is)
CLOUDFLARE_WORKER=https://late-salad-9d56.youngwanga254.workers.dev

# ===== API ENDPOINTS =====
# Elite ProTech API (for ssweb and other tools)
ELITE_PROTECH_API=https://eliteprotech-apis.zone.id

# ===== BOT MEDIA =====
# Bot profile picture URL (optional)
BOT_PIC=https://files.catbox.moe/u29yah.jpg

# ===== TIMEZONE =====
# Your timezone (default: Africa/Nairobi)
TIMEZONE=Africa/Nairobi

# ===== DATABASE =====
# Enable/disable database (json)
DATABASE_ENABLED=true

# ===== FOOTER =====
# Footer text for messages
FOOTER=© 𝐌𝐄𝐆𝐀𝐍-𝐌𝐃